// Prisma schema for the Millionaire Quiz app.
// Local dev uses SQLite; production uses PostgreSQL. The `provider` below is
// switched with `node scripts/set-db-provider.mjs <sqlite|postgresql>`.
// The schema deliberately avoids provider-specific native types so it ports cleanly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTIPLE_SELECT
  SHORT_TEXT
  NUMERIC
  POLL
}

enum ScoringMode {
  WEIGHTED // per-answer points (+ optional speed bonus)
  ESCALATING // millionaire-style: question value rises Q1 -> Qn
}

enum ValueSource {
  PRESET // computed default ladder / curve
  CUSTOM // host-authored values
}

enum SessionStatus {
  LOBBY
  IN_PROGRESS
  ENDED
}

// ---------- Host accounts ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  questionSets QuestionSet[]
  games        Game[]
}

// ---------- Reusable question lists ----------

model QuestionSet {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions Question[]
  games     Game[]

  @@index([ownerId])
}

model Question {
  id               String       @id @default(cuid())
  questionSetId    String
  order            Int
  type             QuestionType @default(MULTIPLE_CHOICE)
  title            String
  timeLimitSeconds Int          @default(20)
  basePoints       Int          @default(1000) // value for ESCALATING / non-weighted correct answers

  // SHORT_TEXT: JSON-encoded array of accepted answers (normalized at scoring time)
  acceptedAnswers  String?
  // NUMERIC: target value and +/- tolerance for a correct answer
  numericAnswer    Float?
  numericTolerance Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionSet QuestionSet @relation(fields: [questionSetId], references: [id], onDelete: Cascade)
  options     Option[]
  responses   Response[]

  @@index([questionSetId])
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  order      Int
  text       String
  isCorrect  Boolean  @default(false)
  points     Int      @default(0) // weighted value for ScoringMode.WEIGHTED

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

// ---------- A game = a campaign that groups live sessions ----------

model Game {
  id            String      @id @default(cuid())
  ownerId       String
  questionSetId String
  title         String
  scoringMode   ScoringMode @default(WEIGHTED)
  valueSource   ValueSource @default(PRESET)
  speedBonus    Boolean     @default(true)
  // JSON-encoded extra scoring config (e.g. custom escalating ladder by question order)
  config        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questionSet QuestionSet @relation(fields: [questionSetId], references: [id])
  sessions    Session[]

  @@index([ownerId])
  @@index([questionSetId])
}

// ---------- A live play session (room) ----------

model Session {
  id                      String        @id @default(cuid())
  gameId                  String
  joinCode                String        @unique
  status                  SessionStatus @default(LOBBY)
  currentQuestionIndex    Int           @default(-1) // -1 = lobby / not started
  currentQuestionStartedAt DateTime?
  hostSocketId            String?
  startedAt               DateTime?
  endedAt                 DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  game      Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  players   Player[]
  responses Response[]

  @@index([gameId])
}

model Player {
  id        String   @id @default(cuid())
  sessionId String
  nickname  String
  email     String?
  socketId  String?
  connected Boolean  @default(true)
  score     Int      @default(0) // denormalized running score within this session
  joinedAt  DateTime @default(now())

  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  responses Response[]

  @@unique([sessionId, nickname])
  @@index([sessionId])
}

model Response {
  id            String   @id @default(cuid())
  sessionId     String
  questionId    String
  playerId      String
  // JSON-encoded submitted answer: {"optionIds":[...]} | {"text":"..."} | {"number":N}
  answer        String
  chosenOptionId String?
  isCorrect     Boolean  @default(false)
  msToAnswer    Int      @default(0)
  pointsEarned  Int      @default(0)
  createdAt     DateTime @default(now())

  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId, playerId])
  @@index([sessionId, questionId])
  @@index([playerId])
}
