# ---- Server ----
PORT=3000
HOST=0.0.0.0
# Allowed origin(s) for Socket.IO CORS. Use a specific origin in production.
SOCKET_CORS_ORIGIN=*

# ---- Database ----
# SQLite for local dev. Use a Postgres connection string in production, e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/millionaire?schema=public"
DATABASE_URL="file:./dev.db"

# ---- Auth ----
# Secret used to sign host session JWTs. Generate a long random value for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="replace-me-with-a-long-random-secret"
